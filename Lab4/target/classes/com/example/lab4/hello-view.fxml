<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="16.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.lab4.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <TableView fx:id="tabela" prefHeight="280.0" prefWidth="520.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="80.0" text="Id" />
            <TableColumn text="Dane">
                <columns>
                    <TableColumn fx:id="colImie" prefWidth="210.0" text="Imie" />
                    <TableColumn fx:id="colNazwisko" prefWidth="210.0" text="Nazwisko" />
                </columns>
            </TableColumn>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="12.0">
        <TextField fx:id="tfImie" promptText="Imie" prefWidth="180.0" />
        <TextField fx:id="tfNazwisko" promptText="Nazwisko" prefWidth="180.0" />
        <Button text="Dodaj" onAction="#onDodajClick" />
    </HBox>
</VBox>
