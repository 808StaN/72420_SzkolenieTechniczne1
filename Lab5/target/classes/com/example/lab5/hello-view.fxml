<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" spacing="12.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.lab5.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Button text="Uruchom zadania lambda/stream" onAction="#onRunTasksClick"/>
    <TextArea fx:id="outputArea" prefHeight="520.0" prefWidth="860.0" wrapText="true"/>
</VBox>
